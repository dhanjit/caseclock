{
  "name": "caseclock",
  "version": "0.1.0",
  "private": true,
  "description": "Local-first, encrypted statutory-deadline + case-supervision cockpit for Indian police investigators.",
  "license": "MIT",
  "author": "Dhanjit Das",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "dev": "pnpm --filter @caseclock/app dev",
    "build": "pnpm --filter @caseclock/app build",
    "preview": "pnpm --filter @caseclock/app preview",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
